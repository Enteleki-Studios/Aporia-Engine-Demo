{
    "compilerOptions": {
        "allowSyntheticDefaultImports": true,
        "composite": true,
        "declaration": true,
        "declarationMap": true,
        "esModuleInterop": true,
        "incremental": true,
        "jsx": "react",
        "lib": ["dom", "esnext"],
        "module": "esnext",
        "moduleResolution": "bundler",
        "rootDir": ".",
        "sourceMap": true,
        "strict": true,
        "target": "esnext",
        "resolveJsonModule": true,
        "noImplicitAny": true,
        "allowJs": true,
        "exactOptionalPropertyTypes": true,
        "noEmit": false,
        "outDir": "${configDir}/dist",
        "skipLibCheck": true
    }
}
