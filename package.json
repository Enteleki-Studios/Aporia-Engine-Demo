        "redux-logger": "^3.0.6",
        "three": "^0.163.0",
        "uuid": "^9.0.0"
    },
    "workspaces": [
        "./games/*",
        "./packages/*"
    ],
    "prettier": {
        "printWidth": 120,
        "tabWidth": 4,
        "semi": false,
        "singleQuote": true,
        "plugins": [
            "@trivago/prettier-plugin-sort-imports"
