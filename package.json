{
    "name": "gamedev-monorepo",
    "version": "0.1.0",
    "description": "game dev monorepo",
    "repository": "https://github.com/mikeymaxdb/GameDev",
    "main": "index.js",
    "author": "mikeymaxdb",
    "license": "No license",
    "type": "module",
    "scripts": {
        "lint": "eslint games/*/src/ packages/*/src/",
        "prettier": "prettier --write .",
        "test": "vitest"
    },
    "devDependencies": {
        "@eslint/js": "^9.4.0",
        "@trivago/prettier-plugin-sort-imports": "^4.3.0",
        "@types/eslint__js": "^8.42.3",
        "@types/react": "^18.3.2",
        "@types/react-dom": "^18.0.10",
        "@types/react-redux": "^7.1.24",
        "@types/redux-logger": "^3.0.9",
        "@types/three": "^0.167.1",
        "@types/uuid": "^10.0.0",
        "@vitejs/plugin-react": "^4.0.0",
        "eslint": "^8.57.0",
        "prettier": "^3.0.0",
        "sass": "^1.77.2",
        "ts-node": "^10.9.1",
        "typedoc": "^0.26.6",
        "typedoc-plugin-missing-exports": "^3.0.0",
        "typescript": "^5.5.2",
        "typescript-eslint": "^7.12.0",
        "vite": "^5.2.11",
        "vite-plugin-wasm": "^3.3.0",
        "vite-tsconfig-paths": "^5.0.0",
        "vitest": "^2.0.3"
    },
    "dependencies": {
        "@dimforge/rapier3d": "^0.14.0",
        "@gengine/core": "*",
        "@gengine/inspector": "*",
        "@gengine/plugin-rapier3D": "*",
        "@gengine/plugin-threejs": "*",
        "@phosphor-icons/react": "^2.0.15",
        "@reduxjs/toolkit": "^2.2.5",
        "gl-matrix": "beta",
        "postprocessing": "^6.30.2",
        "react": "^18.3.1",
        "react-dom": "^18.2.0",
        "react-redux": "^9.0.3",
        "redux-logger": "^3.0.6",
        "three": "^0.167.1",
        "uuid": "^10.0.0"
    },
    "workspaces": [
        "./games/*",
        "./packages/*"
    ],
    "prettier": {
        "printWidth": 120,
        "tabWidth": 4,
        "semi": false,
        "singleQuote": true,
        "plugins": [
            "@trivago/prettier-plugin-sort-imports"
        ],
        "importOrder": [
            "<THIRD_PARTY_MODULES>",
            "^@gengine/(.*)$",
            "^[~/]",
            "^[./]"
        ],
        "importOrderSeparation": true,
        "importOrderSortSpecifiers": true,
        "overrides": [
            {
                "files": "*.md",
                "options": {
                    "printWidth": 80,
                    "proseWrap": "always"
                }
            }
        ]
    }
}
