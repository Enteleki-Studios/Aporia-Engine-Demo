{
    "compilerOptions": {
        "baseUrl": "src",
        "outDir": "./dist/",
        "sourceMap": true,
        "declaration": true,
        "declarationMap": true,
        "strict": true,
        "module": "es6",
        "target": "es6",
        "jsx": "react",
        "lib": ["dom"],
        "moduleResolution": "node",
        "allowSyntheticDefaultImports": true,
        "paths": {
            "gengine": ["gengine"],
            "dungeon/*": ["games/dungeon/*"],
            "*": [
                "games/dungeon/*"
            ]
        }
    }
}
