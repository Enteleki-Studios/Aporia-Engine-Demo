{
    "compilerOptions": {
        "baseUrl": "src",
        "outDir": "./dist/",
        "sourceMap": true,
        "strict": true,
        "module": "es6",
        "target": "es6",
        "jsx": "react",
        "lib": ["dom"],
        "allowJs": true,
        "moduleResolution": "node",
        "allowSyntheticDefaultImports": true,
        "paths": {
            "components/*": ["Dungeon/components/*"],
            "components": ["Dungeon/components/"],
        },
    }
}
