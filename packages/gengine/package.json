        "ts-node": "^10.9.1",
        "typedoc": "^0.24.4",
        "typedoc-plugin-missing-exports": "^2.0.0",
        "vite": "^4.3.3",
        "vite-plugin-dts": "^3.2.0",
        "vite-plugin-static-copy": "^0.16.0"
    },
    "dependencies": {
        "@reduxjs/toolkit": "^1.9.3",
        "gl-matrix": "beta",
        "postprocessing": "^6.30.2",
