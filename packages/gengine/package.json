{
    "name": "gengine",
    "version": "0.1.0",
    "type": "module",
    "files": [
        "dist"
    ],
    "main": "./dist/gengine.umd.cjs",
    "module": "./dist/gengine.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/gengine.js",
            "require": "./dist/gengine.umd.cjs"
        },
        "./style": "./dist/style.css"
    },
    "scripts": {
        "start": "vite build --watch",
        "build": "vite build",
        "build:docs": "typedoc",
        "build:docs:watch": "typedoc --watch",
        "test": "jest",
        "typecheck": "tsc --noEmit",
        "lint": "eslint src",
        "lint:fix": "eslint src --fix",
        "prettier": "prettier --config ../../.prettier.json --check .",
        "prettier:fix": "prettier --config ../../.prettier.json --write ."
    },
    "devDependencies": {
        "@types/react": "^18.0.26",
        "@types/react-redux": "^7.1.24",
        "@types/three": "^0.152.0",
        "@types/uuid": "^9.0.0",
        "@vitejs/plugin-react": "^4.0.0",
        "typedoc": "^0.24.4",
        "typedoc-plugin-missing-exports": "^2.0.0",
        "vite": "^4.3.3",
        "vite-plugin-dts": "^2.3.0",
        "vite-plugin-static-copy": "^0.15.0"
    },
    "dependencies": {
        "@reduxjs/toolkit": "^1.9.3",
        "gl-matrix": "4.0.0-beta.1",
        "postprocessing": "^6.30.2",
        "react": "^18.2.0",
        "react-redux": "^8.0.5",
        "three": "^0.152.2",
        "uuid": "^9.0.0"
    },
    "peerDependencies": {
        "react": "^18.2.0",
        "react-redux": "^8.0.5",
        "three": "^0.152.2"
    }
}
