{
    "name": "gengine",
    "version": "0.1.0",
    "type": "module",
    "files": [
        "dist"
    ],
    "main": "./dist/gengine.umd.cjs",
    "module": "./dist/gengine.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/gengine.js",
            "require": "./dist/gengine.umd.cjs"
        },
        "./style": "./dist/style.css"
    },
    "scripts": {
        "start": "vite build --watch",
        "build": "vite build",
        "build:docs": "typedoc",
        "build:docs:watch": "typedoc --watch",
        "test": "jest",
        "typecheck": "tsc --noEmit",
        "lint": "eslint src",
        "lint:fix": "eslint src --fix"
    },
    "devDependencies": {
        "ts-node": "^10.9.1",
        "typedoc": "^0.25.1",
        "typedoc-plugin-missing-exports": "^2.0.0",
        "vite-plugin-dts": "^3.2.0",
        "vite-plugin-static-copy": "^1.0.0"
    },
    "dependencies": {
        "postprocessing": "^6.30.2"
    },
    "peerDependencies": {
        "react": "^18.2.0",
        "react-redux": "^9.0.3",
        "three": "^0.160.0"
    }
}
