{
    "name": "gamedev",
    "version": "3.0.0",
    "description": "",
    "repository": "https://github.com/mikeymaxdb/GameDev",
    "license": "No license",
    "author": "mikeymaxdb",
    "type": "module",
    "main": "index.js",
    "scripts": {
        "build": "vite build",
        "lint": "eslint src",
        "prettier": "prettier --write .",
        "start": "vite",
        "test": "vitest --typecheck",
        "typecheck": "tsc"
    },
    "devDependencies": {
        "@eslint/js": "^9.23.0",
        "@trivago/prettier-plugin-sort-imports": "^5.2.2",
        "@types/eslint__js": "^8.42.3",
        "@types/react": "^19.0.12",
        "@types/react-dom": "^19.0.4",
        "@types/three": "^0.175.0",
        "@types/uuid": "^10.0.0",
        "@vitejs/plugin-react": "^4.3.4",
        "eslint": "^9.23.0",
        "prettier": "^3.5.3",
        "sass-embedded": "^1.86.0",
        "typescript": "^5.8.2",
        "typescript-eslint": "^8.28.0",
        "vite": "^6.2.3",
        "vite-plugin-wasm": "^3.4.1",
        "vite-tsconfig-paths": "^5.1.4",
        "vitest": "^3.0.9"
    },
    "prettier": {
        "printWidth": 100,
        "tabWidth": 4,
        "semi": false,
        "singleQuote": true,
        "plugins": [
            "@trivago/prettier-plugin-sort-imports"
        ],
        "importOrder": [
            "<THIRD_PARTY_MODULES>",
            "^@core$",
            "^@core/(.*)$",
            "^[~/]",
            "^[./]"
        ],
        "importOrderSeparation": true,
        "importOrderSortSpecifiers": true,
        "overrides": [
            {
                "files": "*.md",
                "options": {
                    "printWidth": 80,
                    "proseWrap": "always"
                }
            }
        ]
    },
    "dependencies": {
        "react": "^19.1.0",
        "react-dom": "^19.1.0",
        "remeda": "^2.21.2",
        "three": "^0.175.0",
        "type-fest": "^4.39.1",
        "uuid": "^11.1.0"
    }
}
